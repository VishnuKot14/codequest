# Set these in Vercel → Project Settings → Environment Variables

# Full URL of your Render backend, ending in /api
# Example: https://codequest-api.onrender.com/api
VITE_API_URL=http://localhost:5000/api

# Full URL of your Render backend for WebSockets (no /api suffix, use wss:// in production)
# Example: wss://codequest-api.onrender.com
VITE_WS_URL=ws://localhost:5000
